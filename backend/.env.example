# ── Google Cloud credentials ───────────────────────────────────────────────────
#
# Railway / PaaS: paste the full contents of your service account JSON here.
# The server writes it to /tmp/sa-key.json at startup.
#
#   How to get the JSON:
#   gcloud iam service-accounts keys create /tmp/key.json \
#     --iam-account=voicesewa-backend@<PROJECT_ID>.iam.gserviceaccount.com
#   Then paste the file contents below.
#
GOOGLE_SERVICE_ACCOUNT_JSON=

# GCP project ID — must match the project your service account belongs to.
GOOGLE_CLOUD_PROJECT=voicesewa

# ── Local dev only ─────────────────────────────────────────────────────────────
# If you are running locally with a key file instead of the env var above,
# set this to the file path and leave GOOGLE_SERVICE_ACCOUNT_JSON blank.
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccountKey.json

# ── Server ─────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically. Only set this for local dev.
# PORT=8080

# ── Session TTLs (optional — defaults shown) ───────────────────────────────────
# WAITING_TTL_MS=90000
# RINGING_TTL_MS=60000
# ACTIVE_TTL_MS=7200000
