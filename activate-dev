#!/usr/bin/env sh
# Cross-shell dev environment activator (POSIX + PowerShell + CMD)
# Fully auto-creates SSH config if needed
# Usage:
#   Linux/macOS: source ./activate-dev
#   Windows PowerShell: .\activate-dev.ps1
#   Windows CMD: activate-dev.cmd

HOST="oneplus-gm1901"
IP="100.83.124.11"
USER="u0_a459"
PORT="8022"
DEV_HOME="$HOME/services/voicesewa_backend"

fail() {
    echo "[activate-dev] ERROR: $1"
    return 1 2>/dev/null || exit 1
}

# ================= POSIX / Bash / Zsh =================
if [ -n "$BASH_VERSION" ] || [ -n "$ZSH_VERSION" ]; then
    echo "[activate-dev] POSIX shell detected"

    # Check Tailscale
    if ! command -v tailscale >/dev/null 2>&1; then
        echo "[activate-dev] DEV ENV NOT SET: Tailscale not installed."
        return 0 2>/dev/null || exit 0
    fi
    if ! tailscale status | grep -q "$HOST"; then
        echo "[activate-dev] DEV ENV NOT SET: $HOST not found in Tailscale. Ask key from backend handler."
        return 0 2>/dev/null || exit 0
    fi

    # Ensure SSH config exists
    mkdir -p ~/.ssh
    if ! grep -q "Host $HOST" ~/.ssh/config 2>/dev/null; then
        cat >> ~/.ssh/config <<EOF

Host $HOST
  HostName $IP
  User $USER
  Port $PORT
EOF
        chmod 700 ~/.ssh
        chmod 600 ~/.ssh/config
        echo "[activate-dev] SSH config for $HOST created automatically."
    fi

    # Test SSH connectivity (non-fatal)
    if ! ssh -o ConnectTimeout=5 -o BatchMode=no "$HOST" "echo connected" >/dev/null 2>&1; then
        echo "[activate-dev] DEV ENV NOT SET: Cannot SSH into $HOST. Ask key from backend handler."
        return 0 2>/dev/null || exit 0
    else
        echo "[activate-dev] SSH test passed."
    fi

    # Set environment
    export DEV_HOME
    export PATH="$DEV_HOME/bin:$PATH"

    # Aliases / functions
    alias ssh-phone="ssh $HOST"
    alias deploy-backend="ssh $HOST 'cd ~/services/voicesewa_backend && ./deploy-and-restart.sh'"
    alias stop-backend="ssh $HOST 'cd ~/services/voicesewa_backend && ./stop-backend.sh'"
    alias view-logs="ssh $HOST 'tail -f ~/services/voicesewa_backend/logs/backend.log'"

    backend-status() {
        STATUS=$(curl -s -o /dev/null -w "%{http_code}" "http://$HOST.orthrus-mahi.ts.net:3000/api/deploy/status")
        if [ "$STATUS" -eq 200 ]; then
            echo "[backend-status] Backend is running."
        else
            echo "[backend-status] Backend is stopped or unreachable (HTTP $STATUS)."
        fi
    }

    # Deactivation function
    deactivate-dev() {
        unset DEV_HOME PATH ssh-phone deploy-backend stop-backend view-logs backend-status
        echo "[activate-dev] Environment deactivated"
    }

    echo "[activate-dev] Environment ready. Aliases/Functions: ssh-phone, deploy-backend, stop-backend, view-logs, backend-status, deactivate-dev"
    return 0 2>/dev/null || exit 0
fi

# ================= Windows PowerShell =================
if [ -n "$PSVersionTable" ] 2>/dev/null; then
    Write-Host "[activate-dev] PowerShell detected"

    if (-not (Get-Command tailscale -ErrorAction SilentlyContinue)) {
        Write-Host "[activate-dev] DEV ENV NOT SET: Tailscale not installed."
        return
    }

    if (-not (tailscale status | Select-String $HOST)) {
        Write-Host "[activate-dev] DEV ENV NOT SET: $HOST not found in Tailscale. Ask key from backend handler."
        return
    }

    $SshDir = "$HOME\.ssh"
    $Config = "$SshDir\config"
    New-Item -ItemType Directory -Force -Path $SshDir | Out-Null
    New-Item -ItemType File -Force -Path $Config | Out-Null

    if (-not (Select-String -Path $Config -Pattern "Host $HOST" -Quiet)) {
@"
Host $HOST
  HostName $IP
  User $USER
  Port $PORT
"@ | Add-Content $Config
        Write-Host "[activate-dev] SSH config for $HOST created automatically."
    }

    try { ssh $HOST "echo connected" } catch {
        Write-Host "[activate-dev] DEV ENV NOT SET: Cannot SSH into $HOST. Ask key from backend handler."
        return
    }

    $env:DEV_HOME="$HOME\services\voicesewa_backend"
    $env:PATH="$env:DEV_HOME\bin;$env:PATH"

    # Functions
    function ssh-phone { ssh $HOST }
    function deploy-backend { ssh $HOST "cd ~/services/voicesewa_backend && ./deploy-and-restart.sh" }
    function stop-backend { ssh $HOST "cd ~/services/voicesewa_backend && ./stop-backend.sh" }
    function view-logs { ssh $HOST "tail -f ~/services/voicesewa_backend/logs/backend.log" }
    function backend-status {
        $status = (Invoke-WebRequest -UseBasicParsing -Uri "http://$HOST.orthrus-mahi.ts.net:3000/api/deploy/status").StatusCode
        if ($status -eq 200) {
            Write-Host "[backend-status] Backend is running."
        } else {
            Write-Host "[backend-status] Backend is stopped or unreachable (HTTP $status)."
        }
    }

    # Deactivation
    function deactivate-dev {
        Remove-Item env:DEV_HOME -ErrorAction SilentlyContinue
        Remove-Item function:ssh-phone,function:deploy-backend,function:stop-backend,function:view-logs,function:backend-status -ErrorAction SilentlyContinue
        Write-Host "[activate-dev] Environment deactivated"
    }

    Write-Host "[activate-dev] Environment ready. Functions: ssh-phone, deploy-backend, stop-backend, view-logs, backend-status, deactivate-dev"
    return
fi

# ================= Windows CMD =================
if defined ComSpec (
    @echo off
    setlocal

    echo [activate-dev] CMD detected

    rem Check if Tailscale is installed
    where tailscale >nul 2>&1
    if errorlevel 1 (
        echo [activate-dev] DEV ENV NOT SET: Tailscale not installed.
        goto SkipCMDSetup
    )

    rem Check if host exists in Tailscale
    tailscale status | findstr /C:"%HOST%" >nul 2>&1
    if errorlevel 1 (
        echo [activate-dev] DEV ENV NOT SET: %HOST% not found in Tailscale. Ask key from backend handler.
        goto SkipCMDSetup
    )

    rem Test SSH connectivity
    ssh -o ConnectTimeout=5 -o BatchMode=yes %USER%@%IP% exit
    if errorlevel 1 (
        echo [activate-dev] DEV ENV NOT SET: Cannot SSH into %HOST%. Ask key from backend handler.
        goto SkipCMDSetup
    )

    rem Set environment variables
    set "PATH=%DEV_HOME%\bin;%PATH%"

    rem Create doskey aliases/macros
    doskey ssh-phone=ssh %USER%@%IP% $*
    doskey deploy-backend=ssh %USER%@%IP% "cd ~/services/voicesewa_backend && ./deploy-and-restart.sh" $*
    doskey stop-backend=ssh %USER%@%IP% "cd ~/services/voicesewa_backend && ./stop-backend.sh" $*
    doskey view-logs=ssh %USER%@%IP% "tail -f ~/services/voicesewa_backend/logs/backend.log" $*
    doskey backend-status=curl -s -o nul -w "%%{http_code}" http://%HOST%.orthrus-mahi.ts.net:3000/api/deploy/status $* || echo [backend-status] Backend is stopped or unreachable

    rem Create deactivate-dev.cmd batch
    (
        echo @echo off
        echo set PATH=%%PATH%%
        echo set DEV_HOME=
        echo echo [activate-dev] Environment deactivated
    ) > deactivate-dev.cmd

    echo [activate-dev] Environment ready. Aliases: ssh-phone, deploy-backend, stop-backend, view-logs, backend-status, deactivate-dev

    goto EndCMDSetup
)

:SkipCMDSetup
echo [activate-dev] CMD environment setup skipped due to missing prerequisites.

:EndCMDSetup
endlocal
